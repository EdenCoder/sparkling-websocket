{
  "name": "sparkling-websocket",
  "version": "0.1.0",
  "description": "Native WebSocket for Lynx/PrimJS — Sparkling Method bridge + JS polyfill (Android & iOS)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./event": {
      "types": "./dist/event.d.ts",
      "import": "./dist/event.js"
    },
    "./polyfill": {
      "types": "./dist/polyfill.d.ts",
      "import": "./dist/polyfill.js"
    },
    "./install": {
      "types": "./dist/install.d.ts",
      "import": "./dist/install.js"
    }
  },
  "files": [
    "dist",
    "src",
    "android/src",
    "android/build.gradle.kts",
    "ios",
    "module.config.json"
  ],
  "scripts": {
    "build": "tsc",
    "codegen": "sparkling-method-cli codegen",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["lynx", "websocket", "primjs", "sparkling-method", "react-lynx"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EdenCoder/sparkling-websocket"
  },
  "dependencies": {
    "sparkling-method": "^2.0.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
